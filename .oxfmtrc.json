{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "useTabs": false,
  "tabWidth": 2,
  "printWidth": 120,
  "singleQuote": true,
  "jsxSingleQuote": false,
  "quoteProps": "as-needed",
  "trailingComma": "all",
  "semi": true,
  "arrowParens": "always",
  "bracketSameLine": false,
  "bracketSpacing": true,
  "ignorePatterns": [
    ".agents/**",
    ".claude/**",
    ".husky/**",
    "node_modules/**",
    "dist/**",
    "build/**",
    "pnpm-lock.yaml",
    "pnpm-workspace.yaml",
    "skills-lock.json"
  ]
}
