# EditorConfig - Formatting settings for oxfmt
# https://editorconfig.org

root = true

[*]
end_of_line = lf
insert_final_newline = true

# Matches multiple files with brace expansion notation
# Set default charset
[*.{js,ts,py}]
charset = utf-8
indent_style = space
indent_size = 2
quote_type = single

# [*.md]
# trim_trailing_whitespace = false
# max_line_length = off

