{
  "name": "telegram-agent",
  "version": "0.1.0",
  "description": "Telegram agent with webhook support and skills integration",
  "keywords": [
    "artusx",
    "telegram",
    "agent",
    "acp"
  ],
  "main": "dist/index.ts",
  "bin": {
    "telegram-agent": "./dist/index.ts"
  },
  "scripts": {
    "build": "npm run tsc",
    "dev": "ARTUS_SERVER_ENV=development npx nodemon src/index.ts",
    "start": "ARTUS_SERVER_ENV=production node dist/index.js",
    "tsc": "rm -rf dist && tsc",
    "lint": "biome check ./src/**/*.ts",
    "lint:fix": "biome check ./src/**/*.ts --write",
    "format": "biome format ./src/**/*.ts --write",
    "test": "vitest run"
  },
  "dependencies": {
    "@agentclientprotocol/sdk": "latest",
    "@artusx/core": "latest",
    "@artusx/utils": "latest",
    "@grammyjs/stream": "^1.0.1",
    "grammy": "^1.41.1",
    "reflect-metadata": "^0.1.13",
    "socks-proxy-agent": "^8.0.5",
    "tslib": "^2.8.1",
    "yaml": "^2.8.3"
  },
  "devDependencies": {
    "@artusx/tsconfig": "latest",
    "@types/node": "^18.11.17",
    "nodemon": "^3.1.14",
    "ts-node": "^10.9.2",
    "typescript": "^5",
    "vitest": "^1.0.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "license": "MIT",
  "author": "Suyi <thonatos.yang@gmail.com>",
  "homepage": "https://github.com/thonatos/claude-code-monorepo",
  "repository": {
    "type": "git",
    "url": "https://github.com/thonatos/claude-code-monorepo.git"
  }
}
